#: addon\appModules\unigram.py:787
msgid "Play/pause the voice message currently playing"
msgstr "လက်ရှိဖွင့်နေသည့် အသံမက်ဆေ့ဂျ်ကို ဖွင့်/ရပ်ပါ။"

