msgid "Video call not available"
msgstr "ဗီဒီယိုခေါ်ဆိုမှု မရရှိနိုင်ပါ။"

#. Function to open instant view
#: addon\appModules\unigram.py:1242
msgid "Press \"Instant view\" button, if it is included in the current message"
msgstr "လက်ရှိမက်ဆေ့ချ်တွင် ပါဝင်ပါက \"ချက်ခြင်းကြည့်ရှုရန်\" ခလုတ်ကို နှိပ်ပါ။"

#: addon\appModules\unigram.py:1253 addon\appModules\unigram.py:1376 addon\appModules\unigram.py:1383 addon\appModules\unigram.py:1391 addon\appModules\unigram.py:2075
#: addon\appModules\unigram.py:2104 addon\appModules\unigram.py:2113 addon\appModules\unigram.py:2122 addon\appModules\unigram.py:2131
