#: addon\appModules\unigram.py:1017
msgid "There is no open profile"
msgstr "ပရိုဖိုင်ဖွင့်ထားခြင်းမရှိပါ။"

#. Announces the profile name and status in an open chat
#: addon\appModules\unigram.py:1020
msgid "Announce the name and status of an open chat"
msgstr "ဖွင့်ချတ်တစ်ခု၏ အမည်နှင့် အခြေအနေကို ကြေညာပါ။"

#: addon\appModules\unigram.py:1023
msgid "Chat activity tracking is enabled"
msgstr "ချတ်လှုပ်ရှားမှု ခြေရာခံခြင်းကို ဖွင့်ထားသည်။"

#: addon\appModules\unigram.py:1024
msgid "Chat activity tracking is disabled"
msgstr "ချတ်လှုပ်ရှားမှု ခြေရာခံခြင်းကို ပိတ်ထားသည်။"

#. Go to "unread messages" label
#: addon\appModules\unigram.py:1043
